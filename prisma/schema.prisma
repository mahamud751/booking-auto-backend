generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  DELIVERED
  CANCELLED
}

model Business {
  id           String       @id @default(cuid())
  name         String
  ownerName    String
  phone        String
  plan         String       @default("STARTER")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  ownerId      String       @unique
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products     Product[]
  orders       Order[]
  quickReplies QuickReply[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business?
}

model Product {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  sku         String?
  imageUrl     String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id            String      @id @default(cuid())
  businessId    String
  business      Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  productCode   String?
  customerName  String
  customerPhone String
  address       String
  productName   String
  color         String?
  size          String?
  price         Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  source        String      @default("MESSENGER")
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model QuickReply {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title      String
  message    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
